# ──────────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────

# Backend API base URL (used by axios)
VITE_API_URL=http://localhost:5000/api

# Admin panel slug — CHANGE THIS to something long and unguessable!
# This is the URL path users must know to access the admin panel.
# Example: /panel-a7f3d9k2m2p1
# NEVER link this in any public page, navbar, footer, or sitemap.
VITE_ADMIN_SLUG=/secure-panel-x9k2
